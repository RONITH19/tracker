# Optional: override the default products sheet (otherwise the app uses your Vikram sheet via /google-sheet-export).
# Full CSV URL, e.g. https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv&gid=0
VITE_PRODUCTS_SHEET_CSV_URL=

# Optional: how often to re-fetch products (ms). Default 60000 (60 seconds).
VITE_PRODUCTS_REFRESH_MS=60000

